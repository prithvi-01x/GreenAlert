# ─────────────────────────────────────────────
# GreenAlert — Root .gitignore
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ─────────────────────────────
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.output/
.cache/

# ── Environment Variables ─────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS Generated ──────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── TypeScript ────────────────────────────────
*.tsbuildinfo

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ── Package Manager ───────────────────────────
# Keep lockfiles — delete lines below if you don't want to ignore them
# pnpm-lock.yaml
# package-lock.json
# yarn.lock

# ── Backend / Python ──────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Database ──────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Docker ────────────────────────────────────
docker-compose.override.yml

# ── Secrets / Keys ───────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx
serviceAccountKey.json
firebase-adminsdk*.json

# ── Misc ─────────────────────────────────────
*.local
.turbo/
.vercel/
.netlify/
